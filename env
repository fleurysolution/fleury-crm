CI_ENVIRONMENT = development

app.baseURL = 'http://localhost/staging/public/'
app.forceGlobalSecureRequests = false   ; true later on HTTPS
app.CSPEnabled = true

database.default.hostname = localhost
database.default.database = crm_core_dev
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306

security.csrfProtection = cookie
security.tokenRandomize = true
security.regenerate = true
security.redirect = true

session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
session.cookieName = crmcore_session
session.expiration = 7200
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = true
session.savePath = fs_as_ci_sessions

